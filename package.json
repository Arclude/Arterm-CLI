{
  "name": "arterm-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local AI coding agent for your terminal — hybrid Ollama + direct GGUF",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "arterm": "pnpm --filter @arterm/cli arterm"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
